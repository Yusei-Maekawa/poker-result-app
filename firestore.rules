rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // 初期管理者（ブートストラップ用）
    // TODO: "your_firebase_uid" を自分の Firebase Authentication UID に置き換えてください
    // 複数人にしたい場合は配列へUIDを追加してください
    function isBootstrapAdmin() {
      return isSignedIn()
        && request.auth.uid in ['u46u17rpgRWZeDY6jhya888qDZU2'];
    }

    function isManagedAdmin(leagueId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/leagues/$(leagueId)/admins/$(request.auth.uid));
    }

    function isLeagueAdmin(leagueId) {
      return isBootstrapAdmin() || isManagedAdmin(leagueId);
    }

    function isValidAdminCreate(adminUid) {
      return request.resource.data.keys().hasOnly(['uid', 'note', 'addedBy', 'createdAt'])
        && request.resource.data.uid == adminUid
        && request.resource.data.addedBy == request.auth.uid
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 80
        // serverTimestamp() はルール評価時点では型判定で落ちることがあるため request.time で検証
        && request.resource.data.createdAt == request.time;
    }

    match /leagues/{leagueId}/admins/{adminUid} {
      allow get: if isSignedIn()
        && (isBootstrapAdmin() || request.auth.uid == adminUid);
      allow list: if isBootstrapAdmin();
      allow create: if isBootstrapAdmin()
        && adminUid != request.auth.uid
        && !exists(/databases/$(database)/documents/leagues/$(leagueId)/admins/$(adminUid))
        && isValidAdminCreate(adminUid);
      allow update: if false;
      allow delete: if isBootstrapAdmin()
        && adminUid != request.auth.uid;
    }

    function isValidPlayerCreate(playerId) {
      return request.resource.data.keys().hasOnly(
          ['authUid', 'name', 'icon', 'memo', 'isActive', 'createdAt', 'updatedAt'])
        && playerId == request.auth.uid
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 20
        && request.resource.data.icon is string
        && request.resource.data.icon.size() <= 4
        && request.resource.data.memo is string
        && request.resource.data.memo.size() <= 80
        && request.resource.data.isActive == true
        // serverTimestamp() を許可するため request.time と一致させる
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidPlayerUpdate() {
      return request.resource.data.authUid == resource.data.authUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.isActive == resource.data.isActive
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 20
        && request.resource.data.icon is string
        && request.resource.data.icon.size() <= 4
        && request.resource.data.memo is string
        && request.resource.data.memo.size() <= 80
      // 更新時は updatedAt を serverTimestamp() で request.time に合わせる
      && request.resource.data.updatedAt == request.time;
    }

    // 管理者はプレイヤーをBAN（isActiveの切り替え）できる
    // それ以外（authUid / name / icon / memo / createdAt）は変更不可
    function isValidPlayerAdminSetActive() {
      return request.resource.data.authUid == resource.data.authUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.name == resource.data.name
        && request.resource.data.icon == resource.data.icon
        && request.resource.data.memo == resource.data.memo
        && request.resource.data.updatedAt == request.time
        && request.resource.data.isActive is bool;
    }

    // players: 閲覧は全員、登録・更新は本人のみ（ドキュメントID = auth UID）
    match /leagues/{leagueId}/players/{playerId} {
      allow read: if true;
      allow create: if isSignedIn()
        && playerId == request.auth.uid
        && isValidPlayerCreate(playerId);
      allow update: if isSignedIn()
        && (
          // 自分自身のプロフィール更新
          (playerId == request.auth.uid
            && resource.data.authUid == request.auth.uid
            && resource.data.isActive == true
            && isValidPlayerUpdate())
          // 管理者BAN/解除（isActiveのみ）
          || (isLeagueAdmin(leagueId) && isValidPlayerAdminSetActive())
        );
      allow delete: if false;
    }

    // games / results の書き込みは管理者のみ

    match /leagues/{leagueId}/games/{docId} {
      allow read: if true;
      allow write: if isLeagueAdmin(leagueId);
    }

    match /leagues/{leagueId}/results/{docId} {
      allow read: if true;
      allow write: if isLeagueAdmin(leagueId);
    }
  }
}
