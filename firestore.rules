rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // leagues/main 配下の読み取りは全員OK（ログイン不要）
    // 書き込みはログイン済みユーザーのみ（v0.1 では全ログイン済みを管理者扱い）

    match /leagues/{leagueId}/{collection}/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
